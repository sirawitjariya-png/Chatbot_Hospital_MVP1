# =========================================================================
# Required
# =========================================================================
OPENAI_API_KEY=sk-...

# =========================================================================
# LLM models — split so you can pay for quality only where it matters
# =========================================================================
# Cheap model for supervisor, grade_chunks, query expansion
ROUTER_MODEL=gpt-4o-mini
# User-facing model for answer + reflect — upgrade to gpt-4o / gpt-4.1 for quality
ANSWER_MODEL=gpt-4o-mini

# Embeddings — swap requires re-ingest
EMBED_MODEL=text-embedding-3-small

# Hard cap on every OpenAI call (seconds)
OPENAI_TIMEOUT_S=60

# =========================================================================
# Vector DB (ChromaDB by default; path auto-resolves to <repo>/data/chroma)
# =========================================================================
VECTOR_DB=chroma
# CHROMA_DIR=  # override only when mounting externally (e.g. gcsfuse)

# =========================================================================
# Optional reranker — biggest quality lift per dollar (especially Thai)
# =========================================================================
RERANKER=                                  # set to "cohere" to enable
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# =========================================================================
# Web search fallback
# =========================================================================
TAVILY_API_KEY=

# =========================================================================
# Reasoning add-ons
# =========================================================================
ENABLE_REFLECTION=false                    # set true for a polish pass (doubles RAG cost)

# =========================================================================
# /chat endpoint protection
# =========================================================================
# Strongly recommended on Cloud Run. When set, /chat requires header
# "X-API-Key: <this value>". Leave empty for open access in local dev.
CHAT_API_KEY=

# =========================================================================
# Channels
# =========================================================================
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
FB_PAGE_ACCESS_TOKEN=
FB_VERIFY_TOKEN=change-me

# =========================================================================
# Logs (local trace files; Cloud Logging is always written via stdout JSON)
# =========================================================================
# LOGS_DIR=  # defaults to <repo>/logs
